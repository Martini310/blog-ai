# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME=blog-ai
APP_VERSION=0.1.0
ENVIRONMENT=development   # development | staging | production
DEBUG=false
API_V1_STR=/api/v1

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ---------------------------------------------------------------------------
# Database (PostgreSQL + asyncpg)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://blogai:blogai@postgres:5432/blogai
POSTGRES_USER=blogai
POSTGRES_PASSWORD=blogai
POSTGRES_DB=blogai

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ---------------------------------------------------------------------------
# LLM
# ---------------------------------------------------------------------------
LLM_PROVIDER=openai    # openai | mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_TIMEOUT_SECONDS=90

# ---------------------------------------------------------------------------
# Celery
# ---------------------------------------------------------------------------
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_ALWAYS_EAGER=false   # set true for tests

# ---------------------------------------------------------------------------
# Sentry (leave empty to disable)
# ---------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ---------------------------------------------------------------------------
# CORS (comma-separated list of allowed origins)
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---------------------------------------------------------------------------
# Flower (Celery monitoring UI)
# ---------------------------------------------------------------------------
FLOWER_USER=admin
FLOWER_PASSWORD=changeme

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_JSON=true   # set false for local human-readable output

# ---------------------------------------------------------------------------
# Feature limits (fallback free tier)
# ---------------------------------------------------------------------------
MAX_PROJECTS_FREE_TIER=3
MAX_ARTICLES_PER_MONTH_FREE_TIER=20
MAX_TOPICS_PER_PROJECT=50
